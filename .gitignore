# ========================================
# .gitignore для проекта Grants CRM
# Репозиторий: C:\project\src\
# ========================================

# ========================================
# ЗАВИСИМОСТИ
# ========================================
node_modules/
bower_components/
yarn.lock
pnpm-lock.yaml
.yarn/
.pnpm-store/

# ========================================
# СБОРКА И БИЛДЫ
# ========================================
dist/
build/
output/
*.tsbuildinfo
.vite/

# ========================================
# ФАЙЛЫ ОКРУЖЕНИЯ
# ========================================
.env
.env.local
.env.development
.env.test
.env.production
!.env.example
.qwen
.qwen/
.qwen/*
QWEN.md
# ========================================
# ЛОГИ
# ========================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ========================================
# IDE И РЕДАКТОРЫ
# ========================================
.idea/
.vscode/
*.swp
*.swo
*~
.suo
*.sublime-project
*.sublime-workspace
*.md
*.bak
*.tmp
!README.md
# ========================================
# СИСТЕМНЫЕ ФАЙЛЫ
# ========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ========================================
# ТЕСТЫ И ПОКРЫТИЕ
# ========================================
coverage/
*.lcov
test-results.xml
.nyc_output/

# ========================================
# ВРЕМЕННЫЕ ФАЙЛЫ
# ========================================
tmp/
temp/
*.pid
*.seed
*.pid.lock

# ========================================
# БАЗЫ ДАННЫХ (локальные)
# ========================================
*.sqlite
*.sqlite3
*.sqlitedb
*.db

# ========================================
# ИНСТРУМЕНТЫ
# ========================================
.eslintcache
.stylelintcache
.prettierignore

# ========================================
# ЗАГРУЖЕННЫЕ ФАЙЛЫ (документы, файлы пользователей)
# ========================================
backend/uploads/documents/
*.pdf
*.doc
*.docx
*.xls
*.xlsx

# Шаблоны документов (хранятся в репозитории)
!backend/uploads/templates/

# ========================================
# СКРИПТЫ МИГРАЦИЙ И СИДОВ (временные)
# ========================================
token.tmp
*.sql.bak
